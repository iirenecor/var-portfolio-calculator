# VaR Comparison graph
# Monte Carlo 1 day
num_simulations_1day = 10000
simulated_1day = np.random.normal(mean, std, num_simulations_1day)
var_montecarlo_1day_percent = np.percentile(simulated_1day, (1 - confidence_level) * 100)
var_montecarlo_1day_monetary = total_investment * var_montecarlo_1day_percent


print(f"Monte Carlo VaR 1-day (95%): {var_montecarlo_1day_percent:.2%} | {var_montecarlo_1day_monetary:.2f} USD")
methods = ['Historical\n(1-day)', 'Parametric\n(1-day)', 'Monte Carlo\n(1-day)']
var_values = [abs(var_historical_monetary), abs(var_parametric_monetary), abs(var_montecarlo_1day_monetary)]
colors = ["#B2CADF", "#8AAFE0", "#7296DA"]

plt.figure(figsize=(8, 5))
bars = plt.bar(methods, var_values, color=colors, width=0.5)

for bar, val in zip(bars, var_values):
    plt.text(bar.get_x() + bar.get_width()/2, bar.get_height() + 30,
             f'${val:,.0f}', ha='center', fontweight='bold', fontsize=11)

plt.title('VaR Comparison — Three Methods (95% Confidence, $100k Portfolio)', 
          fontweight='bold', fontsize=12)
plt.ylabel('Value at Risk (USD)')
plt.ylim(0, max(var_values) * 1.2)
plt.tight_layout()
plt.savefig('var_comparison.png', dpi=150, bbox_inches='tight')
plt.show()